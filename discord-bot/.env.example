DISCORD_TOKEN=your_bot_token
DISCORD_CLIENT_ID=your_application_client_id
DISCORD_GUILD_ID=your_test_guild_id

# Public URL that users open to finish verification.
# For local testing use a tunnel such as Cloudflare Tunnel/ngrok.
PUBLIC_BASE_URL=http://localhost:3000
PORT=3000

# Optional website badges by Minecraft UUID.
# Format: uuid:owner,shd-team;uuid:admin,mod
PUBLIC_PRESTIGE_BADGES=

# Security/privacy.
IP_HASH_SECRET=replace_with_a_long_random_secret
RULES_VERSION=v1
REQUIRE_VERIFICATION_CONSENT=true

# Discord IDs. Leave blank to skip role/logging actions.
VERIFIED_ROLE_ID=
SUSPICIOUS_ROLE_ID=
DISCORD_RULES_ROLE_ID=
LIFESTEAL_RULES_ROLE_ID=
STAFF_ROLE_IDS=
MACE_ROLE_ID=
TWENTY_HEARTS_ROLE_ID=
NINETEEN_HEARTS_ROLE_ID=
EIGHTEEN_HEARTS_ROLE_ID=
SEVENTEEN_HEARTS_ROLE_ID=
SIXTEEN_HEARTS_ROLE_ID=
FIFTEEN_HEARTS_ROLE_ID=
FOURTEEN_HEARTS_ROLE_ID=
THIRTEEN_HEARTS_ROLE_ID=
TWELVE_HEARTS_ROLE_ID=
ELEVEN_HEARTS_ROLE_ID=
TEN_HEARTS_ROLE_ID=
NINE_HEARTS_ROLE_ID=
EIGHT_HEARTS_ROLE_ID=
SEVEN_HEARTS_ROLE_ID=
SIX_HEARTS_ROLE_ID=
FIVE_HEARTS_ROLE_ID=
FOUR_HEARTS_ROLE_ID=
THREE_HEARTS_ROLE_ID=
TWO_HEARTS_ROLE_ID=
ONE_HEARTS_ROLE_ID=
ELIMINATED_ROLE_ID=
DRAGON_EGG_ROLE_ID=
MOD_LOG_CHANNEL_ID=
VERIFY_LOG_CHANNEL_ID=
SECURITY_LOG_CHANNEL_ID=
MINECRAFT_LOG_CHANNEL_ID=
APPEAL_LOG_CHANNEL_ID=
STAFF_AUDIT_CHANNEL_ID=
TICKET_NOTIFY_CHANNEL_ID=
TICKET_ARCHIVE_CHANNEL_ID=
SUPPORT_APPLICATION_LOG_CHANNEL_ID=

# Minecraft integration. RCON is optional but recommended for whitelist/ban sync.
MINECRAFT_RCON_HOST=127.0.0.1
MINECRAFT_RCON_PORT=25575
MINECRAFT_RCON_PASSWORD=
MINECRAFT_RCON_ENABLED=false

# Shared secret for future website or Minecraft plugin hooks.
API_SHARED_SECRET=replace_with_a_long_random_api_secret

# Optional stream overlay state. Only this Minecraft UUID is persisted from gameplay syncs.
OVERLAY_LIFESTEAL_PLAYER_UUID=
OVERLAY_PUBLIC_TOKEN=
