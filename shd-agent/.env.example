SERVER_ID=lifesteal-g17
NODE_ENV=production
API_URL=https://verify.shd-esports.com
API_SHARED_SECRET=replace_with_discord_bot_API_SHARED_SECRET
HEARTBEAT_INTERVAL_SECONDS=15
ACTION_POLL_INTERVAL_SECONDS=20
ACTIONS_ENABLED=false
DISK_PATH=/opt/shd

MINECRAFT_SERVICE_NAME=lifesteal
MINECRAFT_PROCESS_MATCH=fabric-server-launch.jar
MINECRAFT_SERVER_DIR=/opt/shd/lifesteal/server
MINECRAFT_LOG_PATH=/opt/shd/lifesteal/server/logs/latest.log
MINECRAFT_CRASH_DIR=/opt/shd/lifesteal/server/crash-reports
MINECRAFT_QUERY_ENABLED=true
MINECRAFT_QUERY_HOST=127.0.0.1
MINECRAFT_QUERY_PORT=25565

BACKUP_DIR=/opt/shd/lifesteal/backups
BACKUP_SCRIPT=/opt/shd/lifesteal/scripts/backup-lifesteal.sh
BACKUP_MAX_AGE_HOURS=24
BACKUP_RETENTION_DAYS=14

MODS_REPO_DIR=/opt/shd/deploy/lifesteal-mods
ACTIVE_MODS_DIR=/opt/shd/lifesteal/server/mods
MOD_BACKUP_DIR=/opt/shd/lifesteal/backups/mods

CONFIGS_REPO_DIR=/opt/shd/deploy/lifesteal-configs
ACTIVE_CONFIG_DIR=/opt/shd/lifesteal/server/config
CONFIG_BACKUP_DIR=/opt/shd/lifesteal/backups/configs
CONFIG_DEPLOY_ALLOWLIST=

RCON_HOST=127.0.0.1
RCON_PORT=25575
RCON_PROBE_ENABLED=false
