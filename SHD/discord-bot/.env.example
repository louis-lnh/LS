DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=

PORT=3010
PUBLIC_BASE_URL=http://localhost:3010
DATA_FILE=./data/shd-bot.json
API_SHARED_SECRET=
SHD_SITE_INTERNAL_API_BASE_URL=http://localhost:3000/api/internal/bot
SHD_SITE_INTERNAL_TOKEN=

# Only enable after turning on Server Members Intent for this app in the Discord Developer Portal.
ENABLE_GUILD_MEMBERS_INTENT=false
# Only enable after turning on Message Content Intent for this app in the Discord Developer Portal.
ENABLE_MESSAGE_CONTENT_INTENT=false

# Comma-separated Discord user IDs that can always use owner-level bot/admin features.
ADMIN_OWNER_IDS=

# Comma-separated role IDs. Keep broad groups here; feature-specific roles can be added later.
STAFF_ROLE_IDS=
ADMIN_ROLE_IDS=
MODERATOR_ROLE_IDS=
SUPPORT_ROLE_IDS=
DEVELOPER_ROLE_IDS=

# Common SHD member/public roles. These are optional in the backend foundation.
SHD_MEMBER_ROLE_ID=
SHD_VERIFIED_ROLE_ID=
SHD_ANNOUNCEMENTS_ROLE_ID=
SHD_EVENTS_ROLE_ID=
SHD_SUPPORT_PING_ROLE_ID=
SHD_LIVE_ROLE_ID=

# Channel IDs for operational logging.
SECURITY_LOG_CHANNEL_ID=
STAFF_AUDIT_CHANNEL_ID=
SUPPORT_LOG_CHANNEL_ID=
SYSTEM_LOG_CHANNEL_ID=
TICKET_NOTIFY_CHANNEL_ID=
TICKET_ARCHIVE_CHANNEL_ID=
TWITCH_LIVE_CHANNEL_ID=

# Twitch live notifications. Usernames are comma-separated Twitch login names.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_USERNAMES=
TWITCH_POLL_INTERVAL_MS=120000

# Website/admin origins. Comma-separated exact origins, e.g. https://shd.gg,https://admin.shd.gg
ALLOWED_ORIGINS=http://localhost:5176,http://localhost:5177,http://localhost:5178
PUBLIC_SITE_URL=
SUPPORT_SITE_URL=
ADMIN_SITE_URL=

# Discord OAuth for browser admin portal sessions.
DISCORD_CLIENT_SECRET=
ADMIN_SESSION_SECRET=
ADMIN_PORTAL_URL=http://localhost:5178
ADMIN_OAUTH_REDIRECT_URL=http://localhost:3010/api/v1/admin/auth/callback

# Public write protection for support/contact/application/appeal/report intake.
PUBLIC_WRITE_RATE_LIMIT_WINDOW_MS=60000
PUBLIC_WRITE_RATE_LIMIT_MAX=12

# Public status payload defaults.
PUBLIC_STATUS_MESSAGE=SHD systems are being prepared.
PUBLIC_STATUS_STATE=setup

# Server-to-server admin API requests may pass X-SHD-Staff-Id.
